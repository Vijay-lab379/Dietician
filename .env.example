# ============================================================
#  NourishAI — Environment Variables EXAMPLE
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env — only commit this .env.example file.
# ============================================================

# ── OpenRouter (https://openrouter.ai/keys) ──────────────────
OPENROUTER_KEY_1=sk-or-v1-YOUR_OPENROUTER_KEY
# OPENROUTER_KEY_2=sk-or-v1-TEAMMATE_KEY_2

# ── Groq (https://console.groq.com/keys) ─────────────────────
GROQ_KEY_1=gsk_YOUR_GROQ_KEY
# GROQ_KEY_2=gsk_TEAMMATE_KEY_2

# ── Google Gemini (https://aistudio.google.com/app/apikey) ───
GEMINI_KEY_1=YOUR_GEMINI_KEY
# GEMINI_KEY_2=TEAMMATE_GEMINI_KEY_2

# ── Server ───────────────────────────────────────────────────
PORT=3000
